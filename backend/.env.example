# Server
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=apppass
DB_NAME=theatre_booking
DB_CONNECTION_LIMIT=10

# Keycloak (OIDC)
# OIDC_ISSUER may be a comma-separated list of valid issuers — useful
# when the same realm is reachable from the host AND from an Android
# emulator (10.0.2.2). They must all point to the same realm.
OIDC_ISSUER=http://localhost:8080/realms/theatre-booking,http://10.0.2.2:8080/realms/theatre-booking
OIDC_JWKS_URI=http://localhost:8080/realms/theatre-booking/protocol/openid-connect/certs
OIDC_AUDIENCE=account
